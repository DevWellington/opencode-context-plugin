{
  "name": "library",
  "description": "Library/module project template with examples folder",
  "type": "library",
  "createdAt": "2026-04-01T00:00:00Z",
  "structure": {
    "folders": [
      ".opencode",
      ".opencode/context-session",
      ".opencode/context-session/reports",
      "src",
      "tests",
      "examples",
      "docs"
    ],
    "files": []
  },
  "config": {
    "opencode": {
      "contextSession": {
        "enabled": true,
        "maxContexts": 5,
        "autoInject": false
      }
    }
  },
  "hooks": [
