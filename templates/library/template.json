      "event": "session.compacted",
      "action": "saveContext",
      "description": "Save context after session compaction"
    },
    {
      "event": "session.compacted",
      "action": "runTests",
      "description": "Run tests after compaction to verify library integrity"
    }
  ],
  "patterns": [
    {
      "pattern": "Public API via index exports",
      "weight": 8
    },
    {
      "pattern": "Version semver tagging",
      "weight": 7
    },
    {
      "pattern": "Atomic writes for changelog updates",
      "weight": 6
    }
  ]
